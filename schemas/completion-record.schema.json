{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/tesserine/groundwork/main/schemas/completion-record.schema.json",
  "title": "Completion Record",
  "description": "Validates the content of a completion-record artifact. The terminal artifact — captures the final state of a work unit for archival.",
  "type": "object",
  "required": ["work_unit", "criterion_summary", "gaps", "merge_reference", "documentation_status"],
  "additionalProperties": false,
  "properties": {
    "work_unit": {
      "type": "string",
      "description": "Common envelope — threads to work unit.",
      "pattern": "^[a-z][a-z0-9]*([-.][a-z0-9]+)*$"
    },
    "criterion_summary": {
      "type": "string",
      "description": "How acceptance criteria were met.",
      "minLength": 1
    },
    "gaps": {
      "type": "array",
      "description": "Known gaps or deferred work. Empty if none.",
      "items": {
        "type": "string"
      }
    },
    "merge_reference": {
      "type": "string",
      "description": "Merge commit SHA or PR URL.",
      "minLength": 1
    },
    "documentation_status": {
      "type": "string",
      "description": "Summary of documentation coverage.",
      "minLength": 1
    }
  }
}
