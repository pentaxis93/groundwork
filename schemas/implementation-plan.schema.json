{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/tesserine/groundwork/main/schemas/implementation-plan.schema.json",
  "title": "Implementation Plan",
  "description": "Validates the content of an implementation-plan artifact. Bridges behavior (from specify) to code (in implement) with design decisions and scenario-to-step mappings.",
  "type": "object",
  "required": ["work_unit", "summary", "design_decisions", "affected_files", "behavior_mapping"],
  "additionalProperties": false,
  "properties": {
    "work_unit": {
      "type": "string",
      "description": "Common envelope — threads to work unit.",
      "pattern": "^[a-z][a-z0-9]*([-.][a-z0-9]+)*$"
    },
    "summary": {
      "type": "string",
      "description": "What the plan accomplishes.",
      "minLength": 1
    },
    "design_decisions": {
      "type": "array",
      "description": "Decisions with rationale.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/decision"
      }
    },
    "affected_files": {
      "type": "array",
      "description": "Files or modules that get changed.",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "behavior_mapping": {
      "type": "array",
      "description": "How scenarios map to implementation steps.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/mapping"
      }
    }
  },
  "$defs": {
    "decision": {
      "type": "object",
      "description": "A design decision with rationale.",
      "required": ["decision", "rationale"],
      "additionalProperties": false,
      "properties": {
        "decision": {
          "type": "string",
          "description": "What was decided.",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "description": "Why — traces to constraints or principles.",
          "minLength": 1
        }
      }
    },
    "mapping": {
      "type": "object",
      "description": "Mapping from a behavior-contract scenario to implementation steps.",
      "required": ["scenario", "steps"],
      "additionalProperties": false,
      "properties": {
        "scenario": {
          "type": "string",
          "description": "Scenario name from behavior-contract.",
          "minLength": 1
        },
        "steps": {
          "type": "array",
          "description": "Implementation steps for this scenario.",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
