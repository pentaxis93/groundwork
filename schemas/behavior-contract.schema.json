{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/pentaxis93/groundwork/main/schemas/behavior-contract.schema.json",
  "title": "Behavior Contract",
  "description": "Validates the content of a behavior-contract artifact. Defines expected system behavior as Given/When/Then scenarios that trace to acceptance criteria.",
  "type": "object",
  "required": ["work_unit", "title", "scenarios"],
  "additionalProperties": false,
  "properties": {
    "work_unit": {
      "type": "string",
      "description": "Common envelope — threads to work unit.",
      "pattern": "^[a-z][a-z0-9]*([-.][a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "description": "Human-readable title for the behavior contract.",
      "minLength": 1
    },
    "scenarios": {
      "type": "array",
      "description": "Behavioral scenarios in Given/When/Then form.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scenario"
      }
    }
  },
  "$defs": {
    "scenario": {
      "type": "object",
      "description": "A single behavioral scenario tracing to an acceptance criterion.",
      "required": ["name", "criterion", "given", "when", "then"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable scenario name.",
          "minLength": 1
        },
        "criterion": {
          "type": "string",
          "description": "Which acceptance criterion this scenario refines.",
          "minLength": 1
        },
        "given": {
          "type": "string",
          "description": "The initial context or state.",
          "minLength": 1
        },
        "when": {
          "type": "string",
          "description": "The action or event.",
          "minLength": 1
        },
        "then": {
          "type": "string",
          "description": "The expected outcome.",
          "minLength": 1
        }
      }
    }
  }
}
