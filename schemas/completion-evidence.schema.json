{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/pentaxis93/groundwork/main/schemas/completion-evidence.schema.json",
  "title": "Completion Evidence",
  "description": "Validates the content of a completion-evidence artifact. Cross-references other artifacts to demonstrate that completion criteria are met.",
  "type": "object",
  "required": ["behavior-coverage", "review-status", "documentation-status"],
  "additionalProperties": false,
  "properties": {
    "behavior-coverage": {
      "type": "object",
      "description": "References the test-evidence artifact that covers behavior scenarios.",
      "required": ["test-evidence"],
      "additionalProperties": false,
      "properties": {
        "test-evidence": {
          "type": "string",
          "description": "Artifact name referencing test evidence.",
          "pattern": "^[a-z][a-z0-9]*([-.][a-z0-9]+)*$"
        }
      }
    },
    "review-status": {
      "type": "object",
      "description": "References the review-record artifact.",
      "required": ["review-record"],
      "additionalProperties": false,
      "properties": {
        "review-record": {
          "type": "string",
          "description": "Artifact name referencing the review record.",
          "pattern": "^[a-z][a-z0-9]*([-.][a-z0-9]+)*$"
        }
      }
    },
    "documentation-status": {
      "type": "object",
      "description": "References the documentation-review-record artifact.",
      "required": ["documentation-review-record"],
      "additionalProperties": false,
      "properties": {
        "documentation-review-record": {
          "type": "string",
          "description": "Artifact name referencing the documentation review record.",
          "pattern": "^[a-z][a-z0-9]*([-.][a-z0-9]+)*$"
        }
      }
    }
  }
}
